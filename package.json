{
  "name": "mqtt-center-web",
  "version": "1.0.0",
  "description": "MQTT 客户端管理与主题转发 Web 控制台",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mqtt": "^5.10.3",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
